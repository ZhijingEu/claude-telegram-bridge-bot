# .env — secrets only. Personal config (names, calendars, family) goes in telegram_bot/config.yaml.
# Copy this file to .env and fill in your values.

# Telegram Bot token (from @BotFather)
TELEGRAM_BOT_TOKEN=

# Telegram user IDs — numeric IDs for each authorised user
# To find your ID: message @userinfobot on Telegram
PRIMARY_USER_TELEGRAM_ID=       # Primary user (full access)
PARTNER_TELEGRAM_ID=            # Partner / secondary user (optional — leave blank to disable)

# Anthropic API key (for Claude Haiku natural language queries)
# Get yours at: https://console.anthropic.com
ANTHROPIC_API_KEY=
